{
  "name": "jade-static-analysis-repair",
  "displayName": "JADE — Java Static Analysis Repair",
  "publisher": "ruann3res-iftm",
  "description": "Analyze and repair Java static analysis findings with local LLMs, RAG context, traceable reports, and structured feedback.",
  "version": "0.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruann3res/pluginAI.git"
  },
  "bugs": {
    "url": "https://github.com/ruann3res/pluginAI/issues"
  },
  "homepage": "https://github.com/ruann3res/pluginAI#readme",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "java",
    "static analysis",
    "code quality",
    "ai",
    "ollama",
    "llm",
    "rag",
    "quick fix"
  ],
  "activationEvents": [
    "onCommand:JADE.helloWorld",
    "onCommand:JADE.analyzeFile",
    "onCommand:JADE.selectOllamaModel",
    "onCommand:JADE.runModelComparison",
    "onCommand:JADE.runOpenFileModelComparison",
    "onCommand:JADE.exportModelComparisonSamples",
    "onCommand:JADE.exportFeedback",
    "onCommand:JADE.generateFix",
    "onCommand:JADE.openLatestAiReport",
    "onCommand:JADE.openLatestModelComparisonReport",
    "onCommand:JADE.setup",
    "onCommand:JADE.resetSetup"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "JADE",
      "properties": {
        "jade.ollama.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Base URL for the Ollama API."
        },
        "jade.ollama.requestTimeoutMs": {
          "type": "number",
          "default": 900000,
          "description": "Timeout in milliseconds for each Ollama request."
        },
        "jade.ollama.model": {
          "type": "string",
          "default": "deepseek-coder:6.7b",
          "description": "Active Ollama model. Use the command JADE: Select Ollama model to choose one of the supported models."
        },
        "jade.ai.batchMaxLines": {
          "type": "number",
          "default": 180,
          "minimum": 1,
          "description": "Maximum number of Java lines sent per batch to the AI."
        },
        "jade.ai.batchOverlapLines": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "description": "Number of overlapping lines between consecutive batches for context."
        },
        "jade.rag.qdrant.url": {
          "type": "string",
          "default": "http://localhost:6333",
          "description": "Qdrant HTTP URL spun up by `JADE: Setup`. Override only if Docker exposes Qdrant on a different port."
        },
        "jade.rag.embedding.model": {
          "type": "string",
          "default": "nomic-embed-text",
          "description": "Ollama embedding model used by the RAG retriever. Pulled automatically by `JADE: Setup`."
        }
      }
    },
    "commands": [
      {
        "command": "JADE.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "JADE.analyzeFile",
        "title": "JADE: Analyze File"
      },
      {
        "command": "JADE.selectOllamaModel",
        "title": "JADE: Select Ollama model"
      },
      {
        "command": "JADE.runModelComparison",
        "title": "JADE: Run Model Comparison"
      },
      {
        "command": "JADE.runOpenFileModelComparison",
        "title": "JADE: Compare Models on Open Java File"
      },
      {
        "command": "JADE.exportModelComparisonSamples",
        "title": "JADE: Export Model Comparison Samples"
      },
      {
        "command": "JADE.exportFeedback",
        "title": "JADE: Export Feedback"
      },
      {
        "command": "JADE.generateFix",
        "title": "JADE: Generate Fix with AI"
      },
      {
        "command": "JADE.openLatestAiReport",
        "title": "JADE: Open Latest AI Report"
      },
      {
        "command": "JADE.openLatestModelComparisonReport",
        "title": "JADE: Open Latest Model Comparison Report"
      },
      {
        "command": "JADE.setup",
        "title": "JADE: Setup"
      },
      {
        "command": "JADE.resetSetup",
        "title": "JADE: Reset Setup"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "pnpm exec vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.18.0"
  }
}
