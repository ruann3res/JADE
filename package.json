{
  "name": "UDIA",
  "displayName": "UDIA",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:UDIA.helloWorld",
    "onCommand:UDIA.analyzeFile",
    "onCommand:UDIA.selectOllamaModel",
    "onCommand:UDIA.runModelComparison",
    "onCommand:UDIA.runOpenFileModelComparison",
    "onCommand:UDIA.exportModelComparisonSamples",
    "onCommand:UDIA.exportFeedback",
    "onCommand:UDIA.setup",
    "onCommand:UDIA.resetSetup"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "UDIA",
      "properties": {
        "udia.ollama.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Base URL for the Ollama API."
        },
        "udia.ollama.requestTimeoutMs": {
          "type": "number",
          "default": 900000,
          "description": "Timeout in milliseconds for each Ollama request."
        },
        "udia.ollama.model": {
          "type": "string",
          "default": "deepseek-coder:6.7b",
          "description": "Active Ollama model. Use the command UDIA: Select Ollama model to choose one of the supported models."
        },
        "udia.ai.batchMaxLines": {
          "type": "number",
          "default": 180,
          "minimum": 1,
          "description": "Maximum number of Java lines sent per batch to the AI."
        },
        "udia.ai.batchOverlapLines": {
          "type": "number",
          "default": 20,
          "minimum": 0,
          "description": "Number of overlapping lines between consecutive batches for context."
        },
        "udia.rag.qdrant.url": {
          "type": "string",
          "default": "http://localhost:6333",
          "description": "Qdrant HTTP URL spun up by `UDIA: Setup`. Override only if Docker exposes Qdrant on a different port."
        },
        "udia.rag.embedding.model": {
          "type": "string",
          "default": "nomic-embed-text",
          "description": "Ollama embedding model used by the RAG retriever. Pulled automatically by `UDIA: Setup`."
        }
      }
    },
    "commands": [
      {
        "command": "UDIA.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "UDIA.analyzeFile",
        "title": "UDIA: Analyze File"
      },
      {
        "command": "UDIA.selectOllamaModel",
        "title": "UDIA: Select Ollama model"
      },
      {
        "command": "UDIA.runModelComparison",
        "title": "UDIA: Run Model Comparison"
      },
      {
        "command": "UDIA.runOpenFileModelComparison",
        "title": "UDIA: Compare Models on Open Java File"
      },
      {
        "command": "UDIA.exportModelComparisonSamples",
        "title": "UDIA: Export Model Comparison Samples"
      },
      {
        "command": "UDIA.exportFeedback",
        "title": "UDIA: Export Feedback"
      },
      {
        "command": "UDIA.setup",
        "title": "UDIA: Setup"
      },
      {
        "command": "UDIA.resetSetup",
        "title": "UDIA: Reset Setup"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.18.0"
  }
}
